        {
          "original": "学习汉语不能半途而废。",
          "translation": "You can't give up halfway when learning Chinese.",
          "chunks": [
            {
              "text": "学习汉语",
              "meaning": "Learning Chinese"
            },
            {
              "text": "不能半途而废。",
              "meaning": "cannot quit halfway."
            }
          ]
        },
        {
          "original": "我们已经开始，就不能半途而废。",
