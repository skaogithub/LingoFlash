  "cards": [
    {
      "type": "vocabulary",
      "text": "一心一意 (yī xīn yī yì)",
      "translation": "Wholeheartedly / devotedly",
      "sentences": [
        {
          "original": "他一心一意地学习。",
          "translation": "He studies wholeheartedly."
        },
        {
          "original": "我们要一心一意工作。",
          "translation": "We should work with all our hearts."
        }
      ]
    },
    {
      "type": "vocabulary",
      "text": "人山人海 (rén shān rén hǎi)",
      "translation": "Huge crowds of people",
      "sentences": [
        {
          "original": "广场上人山人海。",
          "translation": "The square is packed with people."
        },
        {
          "original": "这里的周末总是人山人海。",
          "translation": "It is always crowded here on weekends.",
          "chunks": [
            {
              "text": "这里的周末",
              "meaning": "Here weekends"
            },
            {
              "text": "总是人山人海。",
              "meaning": "always huge crowds."
            }
          ]
        }
      ]
    },
    {
