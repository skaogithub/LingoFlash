    {
      "type": "vocabulary",
      "text": "おはようございます",
      "translation": "Good morning",
      "sentences": [
        {
          "original": "先生、おはようございます。",
          "translation": "Good morning, teacher.",
          "chunks": [
            {
              "text": "先生、",
              "meaning": "Teacher,"
            },
            {
              "text": "おはようございます。",
              "meaning": "Good morning (polite)."
            }
          ]
        },
        {
          "original": "おはよう。",
          "translation": "Good morning (casual)."
        }
      ]
    },
    {
      "type": "vocabulary",
      "text": "こんにちは",
      "translation": "Hello / Good afternoon",
      "sentences": [
        {
          "original": "皆さん、こんにちは。",
          "translation": "Hello, everyone.",
          "chunks": [
            {
              "text": "皆さん、",
              "meaning": "Everyone,"
            },
            {
              "text": "こんにちは。",
              "meaning": "Hello / Good afternoon."
            }
          ]
        },
        {
          "original": "こんにちは、お元気ですか？",
          "translation": "Hello, how are you?",
          "chunks": [
            {
              "text": "こんにちは、",
              "meaning": "Hello,"
            },
            {
              "text": "お元気ですか？",
              "meaning": "are you healthy?"
            }
          ]
        }
      ]
    },
    {
