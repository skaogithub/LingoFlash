      "sentences": [
        {
          "original": "手伝ってくれて、ありがとうございます。",
          "translation": "Thank you for helping me.",
          "chunks": [
            {
              "text": "手伝ってくれて、",
              "meaning": "For helping me,"
            },
            {
              "text": "ありがとうございます。",
              "meaning": "thank you very much."
            }
          ]
        },
        {
          "original": "本当にありがとうございます。",
          "translation": "Thank you very much.",
          "chunks": [
            {
              "text": "本当に",
              "meaning": "Really"
            },
            {
              "text": "ありがとうございます。",
              "meaning": "thank you very much."
            }
          ]
        }
      ]
    },
    {
