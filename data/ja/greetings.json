            {
              "text": "こんばんは、",
              "meaning": "Good evening,"
            },
            {
              "text": "いい夜ですね。",
              "meaning": "it is a nice night, isn't it?"
            }
          ]
        },
        {
          "original": "田中さん、こんばんは。",
          "translation": "Good evening, Mr. Tanaka.",
