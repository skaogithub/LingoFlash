              "text": "すみません、",
              "meaning": "Excuse me,"
            },
            {
              "text": "トイレはどこですか？",
              "meaning": "where is the toilet?"
            }
          ]
        },
        {
          "original": "遅れてすみません。",
          "translation": "I'm sorry for being late.",
          "chunks": [
            {
              "text": "遅れて",
              "meaning": "Being late"
            },
            {
              "text": "すみません。",
              "meaning": "I am sorry."
            }
          ]
        }
      ]
    },
