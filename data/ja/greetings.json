      "sentences": [
        {
          "original": "もう寝ます。おやすみなさい。",
          "translation": "I'm going to sleep now. Good night.",
          "chunks": [
            {
              "text": "もう寝ます。",
              "meaning": "I am already sleeping / going to sleep."
            },
            {
              "text": "おやすみなさい。",
              "meaning": "Good night."
            }
          ]
        },
        {
          "original": "おやすみ。",
          "translation": "Good night (casual)."
        }
      ]
    },
    {
      "type": "vocabulary",
      "text": "さようなら",
      "translation": "Goodbye",
      "sentences": [
        {
          "original": "先生、さようなら。",
          "translation": "Goodbye, teacher."
        },
        {
          "original": "また明日、さようなら。",
          "translation": "See you tomorrow, goodbye.",
          "chunks": [
            {
              "text": "また明日、",
              "meaning": "Again tomorrow,"
            },
            {
              "text": "さようなら。",
              "meaning": "goodbye."
            }
          ]
        }
      ]
    },
    {
      "type": "vocabulary",
      "text": "ありがとうございます",
