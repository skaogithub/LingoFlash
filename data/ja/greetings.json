            {
              "text": "田中さん、",
              "meaning": "Mr. Tanaka,"
            },
            {
              "text": "こんばんは。",
              "meaning": "Good evening."
            }
          ]
        }
      ]
    },
    {
      "type": "vocabulary",
      "text": "おやすみなさい",
